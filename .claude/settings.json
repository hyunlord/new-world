{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__plugin_oh-my-claudecode_x__ask_codex|Task",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/tools/kanban/hooks/pre-dispatch.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__plugin_oh-my-claudecode_x__ask_codex|Task",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/tools/kanban/hooks/post-dispatch.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/tools/kanban/hooks/session-end.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
