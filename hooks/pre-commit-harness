#!/usr/bin/env bash
# Pre-commit hook: reject commits without harness approval
# Tier-based: none < light < quick < full
set -euo pipefail

STAGED=$(git diff --cached --name-only)
if [[ -z "$STAGED" ]]; then
    exit 0
fi

# ENV-BYPASS (CLAUDE.md Rule 7.1 v3.2.1): a valid env_bypass_active marker
# (≤2 h old, with evidence dir present) authorises THIS commit without a
# harness verdict. Marker is one-shot — deleted here on success so the next
# commit returns to normal gate enforcement.
PROJECT_ROOT_FOR_BYPASS="$(git rev-parse --show-toplevel 2>/dev/null || echo ".")"
BYPASS_MARKER="$PROJECT_ROOT_FOR_BYPASS/.harness/audit/env_bypass_active"
if [[ -f "$BYPASS_MARKER" ]]; then
    bypass_mtime=$(stat -f %m "$BYPASS_MARKER" 2>/dev/null || stat -c %Y "$BYPASS_MARKER" 2>/dev/null || echo 0)
    bypass_age=$(( $(date +%s) - bypass_mtime ))
    if [[ $bypass_age -lt 7200 ]]; then
        bypass_feature=$(grep '^feature:' "$BYPASS_MARKER" 2>/dev/null | head -1 | awk '{print $2}')
        evidence_dir="$PROJECT_ROOT_FOR_BYPASS/.harness/evidence/$bypass_feature"
        if [[ -s "$evidence_dir/manual_verification.log" && -s "$evidence_dir/clippy_full.log" ]]; then
            echo "[pre-commit-harness] ENV-BYPASS active for $bypass_feature (age=${bypass_age}s) — allowing commit (marker consumed)" >&2
            rm -f "$BYPASS_MARKER"
            exit 0
        else
            echo "[pre-commit-harness] ENV-BYPASS marker present but evidence missing under $evidence_dir" >&2
        fi
    else
        echo "[pre-commit-harness] ENV-BYPASS marker expired (age=${bypass_age}s > 7200s) — re-authorize" >&2
        rm -f "$BYPASS_MARKER"
    fi
fi

# STRUCTURAL-COMMIT (v3.3.4): a valid structural_commit_active marker
# (≤2 h old, with cargo_test=PASS + clippy=CLEAN + cold_tier=CONFIRMED)
# authorises THIS commit for direct-implementation work in cold-tier crates
# (sim-core/sim-data/sim-test/sim-bench schema work) without a harness verdict.
# Marker is one-shot — deleted here on success. [STRUCTURAL] tag enforcement
# happens at Layer 1 (tools/harness/hooks/pre-commit-check.sh, sees CMD).
# Layer 2 cannot reliably read COMMIT_EDITMSG before git writes it, so tag
# enforcement is intentionally Layer 1-only (mirrors ENV-BYPASS pattern,
# which also has no Layer 2 tag check).
STRUCT_MARKER="$PROJECT_ROOT_FOR_BYPASS/.harness/audit/structural_commit_active"
if [[ -f "$STRUCT_MARKER" ]]; then
    struct_mtime=$(stat -f %m "$STRUCT_MARKER" 2>/dev/null || stat -c %Y "$STRUCT_MARKER" 2>/dev/null || echo 0)
    struct_age=$(( $(date +%s) - struct_mtime ))
    if [[ $struct_age -lt 7200 ]]; then
        struct_test=$(grep '^cargo_test_result:' "$STRUCT_MARKER" 2>/dev/null | head -1 | awk '{print $2}')
        struct_clippy=$(grep '^clippy_result:' "$STRUCT_MARKER" 2>/dev/null | head -1 | awk '{print $2}')
        struct_cold=$(grep '^cold_tier:' "$STRUCT_MARKER" 2>/dev/null | head -1 | awk '{print $2}')
        struct_feature=$(grep '^feature:' "$STRUCT_MARKER" 2>/dev/null | head -1 | awk '{print $2}')
        if [[ "$struct_test" == "PASS" && "$struct_clippy" == "CLEAN" && "$struct_cold" == "CONFIRMED" ]]; then
            echo "[pre-commit-harness] STRUCTURAL-COMMIT active for $struct_feature (age=${struct_age}s) — allowing commit (marker consumed)" >&2
            rm -f "$STRUCT_MARKER"
            exit 0
        else
            echo "BLOCKED: STRUCTURAL-COMMIT marker malformed (test=$struct_test clippy=$struct_clippy cold=$struct_cold)." >&2
            echo "All 3 fields must be PASS/CLEAN/CONFIRMED. Re-run authorize_structural_commit.sh." >&2
            exit 1
        fi
    else
        echo "[pre-commit-harness] STRUCTURAL-COMMIT marker expired (age=${struct_age}s > 7200s) — re-authorize" >&2
        rm -f "$STRUCT_MARKER"
    fi
fi

if [[ "${HARNESS_SKIP:-}" == "1" ]]; then
    echo "BLOCKED: HARNESS_SKIP=1 is FORBIDDEN per CLAUDE.md Rule 9." >&2
    echo "Diagnose the score gap and fix root cause. Do not bypass." >&2
    exit 1
fi

# Classify by required tier: none < light < quick < full
TIER="none"

while IFS= read -r file; do
    [[ -z "$file" ]] && continue
    case "$file" in
        # Tier: FULL — simulation core logic
        rust/crates/sim-core/*.rs|rust/crates/sim-core/**/*.rs|\
rust/crates/sim-systems/*.rs|rust/crates/sim-systems/**/*.rs|\
rust/crates/sim-engine/*.rs|rust/crates/sim-engine/**/*.rs)
            TIER="full"
            ;;
        # Tier: QUICK — view code (needs Visual Verify + Evaluator)
        *.gd|*.gdshader)
            [[ "$TIER" != "full" ]] && TIER="quick"
            ;;
        # Tier: QUICK — sim data, tests, bridge
        rust/crates/sim-test/*.rs|rust/crates/sim-test/**/*.rs|\
rust/crates/sim-data/*.rs|rust/crates/sim-data/**/*.rs|\
rust/crates/sim-bridge/*.rs|rust/crates/sim-bridge/**/*.rs)
            [[ "$TIER" != "full" ]] && TIER="quick"
            ;;
        # Tier: LIGHT — assets (visual check sufficient)
        *.png|*.svg|*.wav|*.tscn|*.tres|*.ron)
            [[ "$TIER" == "none" ]] && TIER="light"
            ;;
        # Tier: NONE — docs, config, tools, harness infra, localization data,
        # harness governance artifacts (baseline registries, bypass audit log)
        *.md|*.txt|localization/*.json|localization/*/*.json|localization/*/*/*.json|\
localization/*/*.ftl|localization/*/*/*.ftl|\
tools/*|tools/*/*|.claude/*|.claude/*/*|\
.harness/baseline/*|.harness/audit/*|.harness/prompts/*|\
hooks/*|.gitignore|.editorconfig|.gitattributes|*.toml|*.cfg|*.py)
            ;;
        # Unknown — default to quick
        *)
            [[ "$TIER" == "none" || "$TIER" == "light" ]] && TIER="quick"
            ;;
    esac
done <<< "$STAGED"

# NONE tier — free commit
if [[ "$TIER" == "none" ]]; then
    exit 0
fi

# LIGHT, QUICK, FULL — need APPROVED verdict
HARNESS_DIR=".harness"
APPROVED=false
APPROVED_FEATURE=""
# Score threshold: 90 (was 95, lowered 2026-04-24).
# Rationale: VLM login environment issues cause a systematic -8 Visual
# WARNING in every pipeline regardless of code quality. APPROVE verdict +
# CLEAN regression guard + passing tests + clippy clean remain required;
# this change only tolerates the environmental Visual WARNING cost.
# Planned: restore to 95 once vlm-login-env-fix lands.
SCORE_THRESHOLD=90

if [[ -d "$HARNESS_DIR/reviews" ]]; then
    while IFS= read -r -d '' verdict_file; do
        if [[ -f "$verdict_file" ]]; then
            first_line=$(head -1 "$verdict_file")
            if [[ "$first_line" == "APPROVED" ]]; then
                file_epoch=$(sed -n '3p' "$verdict_file" 2>/dev/null || echo "0")
                if [[ "$file_epoch" =~ ^[0-9]+$ ]]; then
                    now_epoch=$(date +%s)
                    file_age=$(( now_epoch - file_epoch ))
                    if [[ $file_age -lt 1800 ]]; then
                        APPROVED=true
                        APPROVED_FEATURE=$(sed -n '2p' "$verdict_file" 2>/dev/null || echo "")
                        break
                    fi
                fi
            fi
        fi
    done < <(find "$HARNESS_DIR/reviews" -name "verdict" -print0 2>/dev/null)
fi

if [[ "$APPROVED" != "true" ]]; then
    echo ""
    echo "==========================================================="
    echo "  BLOCKED: Changes require harness approval (tier: $TIER)"
    echo "==========================================================="
    echo ""
    echo "  Run:  bash tools/harness/harness_pipeline.sh <feature> <prompt.md> --${TIER}"
    echo ""
    echo "==========================================================="
    exit 1
fi

# Score gate: REQUIRED — no score evidence = BLOCK (no silent pass)
if [[ -n "$APPROVED_FEATURE" ]]; then
    score=""
    score_source=""
    verdict_file_path=$(find "$HARNESS_DIR/reviews" -name "verdict" -print0 2>/dev/null | \
        xargs -0 grep -l "^$APPROVED_FEATURE$" 2>/dev/null | head -1)
    # 1st: verdict line 4 (pipeline writes score there)
    if [[ -n "$verdict_file_path" ]]; then
        verdict_score=$(sed -n '4p' "$verdict_file_path" 2>/dev/null || echo "")
        if [[ "$verdict_score" =~ ^[0-9]+$ ]]; then
            score="$verdict_score"
            score_source="verdict:line4"
        fi
    fi
    # 2nd: legacy pipeline_report.md
    if [[ -z "$score" ]]; then
        report_file="$HARNESS_DIR/reports/$APPROVED_FEATURE/pipeline_report.md"
        if [[ -f "$report_file" ]]; then
            score=$(grep -oE '\*\*[0-9]+\*\*' "$report_file" | head -1 | tr -d '*' || echo "")
            [[ -n "$score" ]] && score_source="pipeline_report.md"
        fi
    fi
    # No score found — BLOCK
    if [[ -z "$score" ]]; then
        echo ""
        echo "==========================================================="
        echo "  BLOCKED: No score evidence for feature '$APPROVED_FEATURE'"
        echo "==========================================================="
        echo ""
        echo "  Verdict has no score (line 4 empty) and pipeline_report.md missing."
        echo "  Run: bash tools/harness/harness_pipeline.sh $APPROVED_FEATURE <prompt>"
        echo ""
        echo "==========================================================="
        exit 1
    fi
    # Adjusted score: add back VLM environmental costs per CLAUDE.md Rule 7.
    # "VLM WARNING alone never blocks merge. This is policy, not bug."
    # Detection: absent visual_analysis.txt = VLM SKIP; file starting with
    # VISUAL_WARNING = VLM WARNING. Both are environmental, not code quality.
    adjusted_score="$score"
    vlm_env_cost=0
    vlm_analysis_file="$HARNESS_DIR/evidence/$APPROVED_FEATURE/visual_analysis.txt"
    if [[ ! -f "$vlm_analysis_file" ]]; then
        vlm_env_cost=8
    elif grep -qE "^VISUAL_WARNING" "$vlm_analysis_file" 2>/dev/null; then
        vlm_env_cost=8
    fi
    if [[ "$vlm_env_cost" -gt 0 ]]; then
        adjusted_score=$((score + vlm_env_cost))
    fi
    if [[ "$adjusted_score" -lt "$SCORE_THRESHOLD" ]] 2>/dev/null; then
        echo ""
        echo "==========================================================="
        echo "  BLOCKED: Pipeline score ${score}/100 (adjusted ${adjusted_score}/100) below ${SCORE_THRESHOLD} threshold"
        echo "==========================================================="
        echo ""
        echo "  Feature: $APPROVED_FEATURE (source: $score_source)"
        if [[ "$vlm_env_cost" -gt 0 ]]; then
            echo "  Adjustment +${vlm_env_cost} (VLM env cost per Rule 7) applied but score still below threshold."
        fi
        echo "  Fix the gaps and re-run: bash tools/harness/harness_pipeline.sh $APPROVED_FEATURE <prompt>"
        echo ""
        echo "==========================================================="
        exit 1
    fi
    if [[ "$vlm_env_cost" -gt 0 ]]; then
        echo "[hook] Score $score → adjusted $adjusted_score (+${vlm_env_cost} VLM env cost per Rule 7) ≥ $SCORE_THRESHOLD ✓" >&2
    fi
fi
